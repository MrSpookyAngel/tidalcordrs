# Credentials (change this)
DISCORD_TOKEN="<add-your-bot-discord-token>"

# Runtime configuration
TZ="UTC"

# Optional: use a TOML config file instead of environment overrides.
# For local runs, TidalCordRS automatically reads config.toml from the current directory.
# For Docker, mount the file and set CONFIG_PATH=/app/config/config.toml.
# CONFIG_PATH="/app/config/config.toml"

# Optional Portainer / Docker env overrides.
# TIDALCORDRS_COMMAND_PREFIX="!"
# TIDALCORDRS_BOT_PROFILE__SYNC_ENABLED="true"
# TIDALCORDRS_BOT_PROFILE__NAME="TidalCordRS"
# TIDALCORDRS_BOT_PROFILE__AVATAR_PATH="<path-to-custom-avatar>"
